{
  "name": "parking-web-tool",
  "version": "1.0.0",
  "description": "Private mobile web tool for parking recommendations",
  "type": "module",
  "main": "public/src/ui/app.js",
  "scripts": {
    "test": "node --test tests/unit/*.test.js tests/contract/*.test.js",
    "dev": "node --env-file=.env fetch-parking.mjs",
    "serve": "python3 -m http.server 8080 -d public",
    "deploy:worker": "cd worker && npx wrangler deploy",
    "deploy:pages": "npx wrangler pages deploy public --project-name=parking-web-tool",
    "deploy": "npm test && npm run deploy:worker && npm run deploy:pages"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {}
}
